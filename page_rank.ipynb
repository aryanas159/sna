   "source": [
    "import networkx as nx\n",
    "\n",
    "G = nx.DiGraph()\n",
    "\n",
    "edges = [\n",
    "    (\"A\",\"B\"),\n",
    "    (\"A\",\"C\"),\n",
    "    (\"B\",\"C\"),\n",
    "    (\"C\",\"A\")\n",
    "]\n",
    "\n",
    "G.add_edges_from(edges)\n",
    "\n",
    "pagerank_scores = nx.pagerank(G, alpha=0.85)\n",
    "\n",
    "print(pagerank_scores)"
   ]
  }
 ],
